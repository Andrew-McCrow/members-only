<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Members Only</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container py-5" style="max-width: 700px;">

    <!-- User panel -->
    <div class="card shadow-sm p-4 mb-4">
      <% if (locals.user) { %>
        <h1 class="h4 mb-3 text-center">Welcome back, <strong><%= user.name %></strong>!</h1>
        <% if (user.member_status === 'in_da_club') { %>
          <div class="alert alert-success text-center mb-3">You're In Da Club! 🎉</div>
          <a href="/new-message" class="btn btn-success w-100 mb-2">Create a New Message</a>
        <% } else { %>
          <div class="alert alert-warning text-center mb-3">You're currently in the cold...</div>
          <a href="/join-club" class="btn btn-primary w-100 mb-2">Join the Club</a>
        <% } %>
        <a href="/log-out" class="btn btn-outline-danger w-100">Log Out</a>
      <% } else { %>
        <h1 class="h4 mb-4 text-center">Log In</h1>
        <form action="/log-in" method="POST">
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input id="email" name="email" placeholder="Email" type="email" class="form-control" />
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input id="password" name="password" type="password" class="form-control" />
          </div>
          <button type="submit" class="btn btn-primary w-100">Log In</button>
        </form>
        <hr>
        <p class="text-center mb-0">Don't have an account? <a href="/sign-up">Sign Up</a></p>
      <% } %>
    </div>

    <!-- Messages -->
    <h2 class="h5 mb-3">Club Messages</h2>
    <% if (messages.length === 0) { %>
      <p class="text-muted">No messages yet. Be the first to post!</p>
    <% } %>
    <% messages.forEach(function(msg) { %>
      <div class="card shadow-sm mb-3">
        <div class="card-body">
          <h5 class="card-title"><%= msg.title %></h5>
          <p class="card-text"><%= msg.message %></p>
          <% if (locals.user && user.member_status === 'in_da_club') { %>
            <p class="card-text">
              <small class="text-muted">
                By <strong><%= msg.author_name %></strong> &mdash;
                <%= new Date(msg.timestamp).toLocaleString() %>
              </small>
            </p>
          <% } %>
          <% if (locals.user && user.is_admin) { %>
            <form action="/messages/<%= msg.id %>/delete" method="POST" class="d-inline">
              <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
          <% } %>
        </div>
      </div>
    <% }); %>

  </div>
</body>
</html>

