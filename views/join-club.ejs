<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Join the Club</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-light d-flex align-items-center justify-content-center"
    style="min-height: 100vh"
  >
    <div class="card shadow-sm p-4" style="width: 100%; max-width: 400px">
      <h1 class="h4 mb-1 text-center">Join the Club</h1>
      <p class="text-center text-muted mb-4">Enter the secret passcode to become a member</p>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <form action="/join-club" method="POST">
        <div class="mb-3">
          <label for="passcode" class="form-label">Secret Passcode</label>
          <input
            id="passcode"
            name="passcode"
            type="password"
            class="form-control"
            placeholder="Enter passcode"
          />
        </div>
        <button type="submit" class="btn btn-primary w-100">Join In Da Club</button>
      </form>
      <hr />
      <p class="text-center mb-0"><a href="/">Back to Home</a></p>
    </div>
  </body>
</html>
