<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Message</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-light d-flex align-items-center justify-content-center"
    style="min-height: 100vh"
  >
    <div class="card shadow-sm p-4" style="width: 100%; max-width: 500px">
      <h1 class="h4 mb-4 text-center">Create a New Message</h1>
      <form action="/new-message" method="POST">
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input
            id="title"
            name="title"
            type="text"
            placeholder="Message title"
            value="<%= formData.title || '' %>"
            class="form-control <%= errors.title ? 'is-invalid' : '' %>"
          />
          <% if (errors.title) { %>
            <div class="invalid-feedback"><%= errors.title.msg %></div>
          <% } %>
        </div>
        <div class="mb-3">
          <label for="message" class="form-label">Message</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            placeholder="Write your message..."
            class="form-control <%= errors.message ? 'is-invalid' : '' %>"
          ><%= formData.message || '' %></textarea>
          <% if (errors.message) { %>
            <div class="invalid-feedback"><%= errors.message.msg %></div>
          <% } %>
        </div>
        <button type="submit" class="btn btn-success w-100">Post Message</button>
      </form>
      <hr />
      <p class="text-center mb-0"><a href="/">Back to Home</a></p>
    </div>
  </body>
</html>
